#!/bin/sh

message_file=$1
subject=$(sed -n '1p' "$message_file")

if printf '%s\n' "$subject" \
    | grep -Eq '^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)\([[:alnum:]_.-]+\): .+'; then
    exit 0
fi

cat >&2 <<'EOF'
Invalid commit message.

Use: type(scope): description
Example: feat(storage): validate journal metadata

Allowed types: build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test
EOF

exit 1
